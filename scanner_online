def connect_to_google_sheet():
    try:
        creds_json = os.environ.get('GOOGLE_CREDENTIALS_JSON')
        if creds_json:
            creds_info = json.loads(creds_json)
            creds = Credentials.from_service_account_info(creds_info, scopes=SCOPES)
            print("✓ Loaded credentials from environment variable.")
        else:
            creds = Credentials.from_service_account_file('credentials.json', scopes=SCOPES)
            print("✓ Loaded credentials from local file.")
            
        client = gspread.authorize(creds)
        sheet = client.open(GOOGLE_SHEET_NAME).sheet1
        return sheet
    except Exception as e:
        print(f"✗ Error connecting to Google Sheets: {str(e)}")
        return None

def log_to_local_csv(name, email, qr_data):
    file_name = 'attended.csv'
    file_exists = os.path.isfile(file_name)
    timestamp = datetime.now().strftime("%Y-%m-%d %H:%M:%S")

    try:
        with open(file_name, mode='a', newline='', encoding='utf-8') as f:
            writer = csv.writer(f)
            if not file_exists:
                writer.writerow(['Name', 'Email', 'Time Scanned', 'Unique ID'])
            
            writer.writerow([name, email, timestamp, qr_data])
            print(f"  ↳ Saved to {file_name}")
    except Exception as e:
        print(f"  ✗ Failed to save to local CSV: {e}")

def mark_attendance(qr_data):
    try:
        if not os.path.exists('qr_mapping.csv'):
            return False, "Mapping file 'qr_mapping.csv' missing! Run sender.py first."
        
        mapping_df = pd.read_csv('qr_mapping.csv')
        person = mapping_df[mapping_df['unique_id'] == qr_data]
        
        if person.empty:
            return False, "QR code not recognized"
        
        row_number = int(person.iloc[0]['row_number'])
        name = person.iloc[0][NAME_COLUMN]
        
        email = ""
        if EMAIL_COLUMN in person.columns:
            email = person.iloc[0][EMAIL_COLUMN]

        sheet = connect_to_google_sheet()
        if sheet:
            headers = sheet.row_values(1)
            if ATTENDANCE_COLUMN in headers:
                attendance_col = headers.index(ATTENDANCE_COLUMN) + 1
            else:
                attendance_col = len(headers) + 1
            
            try:
                sheet.update_cell(row_number, attendance_col, "TRUE")
                print(f"✓ Google Sheet updated for {name}")
            except Exception as e:
                print(f"✗ Google Sheet update failed: {e}")
        else:
            print("⚠ Could not connect to Google Sheets (Offline Mode)")

        log_to_local_csv(name, email, qr_data)
        
        return True, name
        
    except Exception as e:
        print(f"✗ Error: {str(e)}")
        return False, str(e)

@app.route('/')
def index():
    return render_template_string(SCANNER_HTML)

@app.route('/mark_attendance', methods=['POST'])
def mark_attendance_route():
    data = request.json
    qr_data = data.get('qr_data', '')
    success, result = mark_attendance(qr_data)
    return {'success': success, 'name' if success else 'message': result}

def get_local_ip():
    try:
        s = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)
        s.connect(("8.8.8.8", 80))
        ip = s.getsockname()[0]
        s.close()
        return ip
    except:
        return "localhost"

if __name__ == "__main__":
    if not os.path.exists('qr_mapping.csv'):
        print("⚠️ WARNING: 'qr_mapping.csv' not found.")
        print("   Please run sender.py first to generate the list of valid codes.")
    else:
        local_ip = get_local_ip()
        print("\n" + "=" * 60)
        print(" QR SCANNER READY")
        print("=" * 60)
        print(f"\n📱 Connect via Mobile: http://{local_ip}:5000")
        print(f"💻 Connect via PC:     http://localhost:5000")
        print("\n📝 Local logs will be saved to: attended.csv")
        print("=" * 60 + "\n")
        
        app.run(host='0.0.0.0', port=5000, debug=False)